# Database
DATABASE_URL=postgresql+asyncpg://crm_user:crm_password@localhost:5432/opensalesclaw
POSTGRES_USER=crm_user
POSTGRES_PASSWORD=crm_password
POSTGRES_DB=opensalesclaw

# Auth
SECRET_KEY=change-me-to-a-long-random-secret-key
ACCESS_TOKEN_EXPIRE_MINUTES=30

# CORS — comma-separated list of allowed origins
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# Seed data
DEFAULT_ADMIN_EMAIL=admin@opensalesclaw.com
DEFAULT_ADMIN_PASSWORD=admin
SEED_DEMO_DATA=false

# Testing — set to point at your local test DB when running pytest outside Docker
TEST_DATABASE_URL=postgresql+asyncpg://crm_user:crm_password@localhost:5432/opensalesclaw_test
